generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = "file:./dev.db"
}

model User {
  id          String   @id @default(cuid())
  email       String   @unique
  username    String?  @unique
  password    String
  name        String?
  avatar      String?
  location    String?
  balconyType String?
  balconySize  Float?
  balconyDirection String?
  preferences Json?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  // Relations
  projects    Project[]
  uploads     Upload[]
  activities  Activity[]
  reminders   Reminder[]
  communities CommunityMembership[]
  purchases   Purchase[]
  comments    Comment[]
  reports     Report[]

  @@map("users")
}

model Plant {
  id          String   @id @default(cuid())
  name        String
  scientificName String?
  commonNames String[]
  category    String   // 'indoor', 'outdoor', 'herb', 'flower', 'vegetable'
  light       String   // 'full-sun', 'partial-sun', 'partial-shade', 'shade'
  water       String   // 'frequent', 'moderate', 'minimal'
  temperature Json?
  humidity    Json?
  soil        String?
  growthRate  String?  // 'fast', 'medium', 'slow'
  matureSize  Json?
  difficulty  Int      @default(3) // 1-5 scale
  description String?
  careTips    String[]
  toxicity    String?  // 'non-toxic', 'toxic-to-pets', 'toxic-to-humans'
  benefits    String[] // 'air-purification', 'easy-care', 'fragrant', etc.
  imageUrl    String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  // Relations
  projectPlants ProjectPlant[]
  knowledge     PlantKnowledge[]
  problems      PlantProblem[]
  seasons       PlantSeason[]

  @@map("plants")
}

model Project {
  id          String   @id @default(cuid())
  name        String
  description String?
  status      String   @default("planning") // 'planning', 'in-progress', 'completed'
  balconyJson Json     // balcony configuration data
  designJson  Json     // design plan data
  location    String?
  area        Float?
  budget      Float?
  startDate   DateTime?
  endDate     DateTime?
  userId      String
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  // Relations
  user        User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  projectPlants ProjectPlant[]
  activities  Activity[]
  reports     Report[]

  @@map("projects")
}

model ProjectPlant {
  id         String   @id @default(cuid())
  projectId  String
  plantId    String
  quantity   Int      @default(1)
  position   Json     // position information in balcony
  notes      String?
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  // Relations
  project    Project @relation(fields: [projectId], references: [id], onDelete: Cascade)
  plant      Plant   @relation(fields: [plantId], references: [id], onDelete: Cascade)

  @@map("project_plants")
}

model PlantKnowledge {
  id          String   @id @default(cuid())
  plantId     String
  title       String
  content     String
  category    String   // 'care', 'propagation', 'disease', 'tip'
  difficulty  Int?     // 1-5 scale
  tags        String[]
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  // Relations
  plant       Plant @relation(fields: [plantId], references: [id], onDelete: Cascade)

  @@map("plant_knowledge")
}

model PlantProblem {
  id          String   @id @default(cuid())
  plantId     String
  name        String
  description String
  symptoms    String[]
  causes      String[]
  solutions   String[]
  imageUrl    String?
  severity    Int      @default(3) // 1-5 scale
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  // Relations
  plant       Plant @relation(fields: [plantId], references: [id], onDelete: Cascade)

  @@map("plant_problems")
}

model PlantSeason {
  id          String   @id @default(cuid())
  plantId     String
  season      String   // 'spring', 'summer', 'autumn', 'winter'
  tasks       String[]
  careTips    String[]
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  // Relations
  plant       Plant @relation(fields: [plantId], references: [id], onDelete: Cascade)

  @@map("plant_seasons")
}

model Upload {
  id        String   @id @default(cuid())
  filename  String
  originalName String
  path      String
  mimetype  String
  size      Int
  type      String   // 'balcony', 'plant', 'result'
  userId    String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Relations
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("uploads")
}

model Activity {
  id          String   @id @default(cuid())
  type        String   // 'upload', 'plant_added', 'care_completed', 'milestone'
  title       String
  description String?
  data        Json?
  projectId   String?
  userId      String
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  // Relations
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  project     Project? @relation(fields: [projectId], references: [id], onDelete: Cascade)

  @@map("activities")
}

model Reminder {
  id          String   @id @default(cuid())
  type        String   // 'water', 'fertilize', 'prune', 'repot'
  title       String
  description String?
  dueDate     DateTime
  completed   Boolean  @default(false)
  projectId   String?
  plantId     String?
  userId      String
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  // Relations
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  project     Project? @relation(fields: [projectId], references: [id], onDelete: Cascade)
  plant       Plant?   @relation(fields: [plantId], references: [id], onDelete: Cascade)

  @@map("reminders")
}

model Community {
  id          String   @id @default(cuid())
  name        String
  description String?
  isPublic    Boolean  @default(true)
  rules       String?
  imageUrl    String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  // Relations
  members     CommunityMembership[]
  posts       Post[]
  comments    Comment[]

  @@map("communities")
}

model CommunityMembership {
  id         String   @id @default(cuid())
  userId     String
  communityId String
  role       String   @default("member") // 'admin', 'moderator', 'member'
  joinedAt   DateTime @default(now())

  // Relations
  user       User       @relation(fields: [userId], references: [id], onDelete: Cascade)
  community  Community  @relation(fields: [communityId], references: [id], onDelete: Cascade)

  @@unique([userId, communityId])
  @@map("community_memberships")
}

model Post {
  id          String   @id @default(cuid())
  title       String
  content     String
  imageUrl    String?
  communityId String
  authorId    String
  isPinned    Boolean  @default(false)
  views       Int      @default(0)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  // Relations
  community   Community @relation(fields: [communityId], references: [id], onDelete: Cascade)
  author      User      @relation(fields: [authorId], references: [id], onDelete: Cascade)
  comments    Comment[]
  reports     Report[]

  @@map("posts")
}

model Comment {
  id          String   @id @default(cuid())
  content     String
  postId      String?
  authorId    String
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  // Relations
  post        Post?    @relation(fields: [postId], references: [id], onDelete: Cascade)
  author      User     @relation(fields: [authorId], references: [id], onDelete: Cascade)
  reports     Report[]

  @@map("comments")
}

model Purchase {
  id          String   @id @default(cuid())
  type        String   // 'plant', 'tool', 'soil', 'fertilizer'
  name        String
  description String?
  price       Float
  quantity    Int      @default(1)
  supplier    String?
  imageUrl    String?
  purchasedAt DateTime @default(now())
  userId      String

  // Relations
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("purchases")
}

model Report {
  id          String   @id @default(cuid())
  type        String   // 'post', 'comment', 'user', 'content'
  reason      String
  description String?
  targetId    String
  reporterId  String
  status      String   @default("pending") // 'pending', 'reviewed', 'resolved'
  reviewedBy  String?
  reviewedAt  DateTime?
  action      String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  // Relations
  reporter    User     @relation(fields: [reporterId], references: [id], onDelete: Cascade)

  @@map("reports")
}

model Weather {
  id        String   @id @default(cuid())
  location  String
  date      DateTime @unique
  temperature Float
  humidity  Float
  precipitation Float
  windSpeed Float
  weatherCondition String
  uvIndex   Int?
  createdAt DateTime @default(now())

  @@map("weather")
}

model Recommendation {
  id          String   @id @default(cuid())
  type        String   // 'plant', 'design', 'care'
  title       String
  description String
  data        Json?
  confidence  Float    // 0-1
  plantId     String?
  projectId   String?
  userId      String
  createdAt   DateTime @default(now())

  // Relations
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  project     Project? @relation(fields: [projectId], references: [id], onDelete: Cascade)
  plant       Plant?   @relation(fields: [plantId], references: [id], onDelete: Cascade)

  @@map("recommendations")
}